InteractionTrigger Eruptor Earth Eruption 32768

TRIGGER Eruption {
DRAW ELEMENT:Magma RANDOMFILLEDCIRCLE  X1 Y1 (10 RAND 30) 1000
DRAW ELEMENT:Eruptor2 FILLEDCIRCLE X1 Y1 2
}

Element None Eruptor2 0 0 0 0 1 0 1 0 Clear 0 Text None

InteractionTrigger Eruptor2 All { 1000
DRAW 0 SWAPPOINTS X1 Y1 X2 (Y1 - 1)
DRAW 0 OBJECT X1 Y1 SIZE 3 a ELEMENT:Lava b ELEMENT:Magma {
" aaa "
"ba ab"
"aaa"
}
CLOSEST ELEMENT:Clear X1 Y1 50
IF (CLOSESTD < 20) {
          EXEC Eruption2 CLOSESTX CLOSESTY
          DRAW ELEMENT:Lava REPLACEFILLEDCIRCLE 0 0 (WIDTH * 2) 0 ELEMENT:Eruptor2
          }
}

TRIGGER Eruption2 {
EXEC LaunchExplosion ELEMENT:Fire 20 (1 RAND 2) 20 200 100 400
EXEC LaunchExplosion ELEMENT:EruptionCloud 40 (1 RAND 2) 100 200 100 200
EXEC ArcExplosion ELEMENT:Fire 50 0 50 120 100 100
EXEC ArcExplosion ELEMENT:Lava 20 1 50 80 50 200
DRAW ELEMENT:Fire FILLEDCIRCLE $0 $1 (20 RAND 70)
DRAW ELEMENT:Lava FILLEDCIRCLE $0 $1 (10 RAND 18)
DRAW ELEMENT:Volcano FILLEDCIRCLE X1 Y1 (10 RAND 22)
DRAW ELEMENT:Earthquake REPLACEFILLEDCIRCLE $0 $1 150 0 ELEMENT:Earth
