GROUP CLEARALL
ELEMENTSCLEAR
MENURIGHT = 70

GROUP Human 80 FILE erase.bmp
GROUP La+Ac 70 FILE erase.bmp
GROUP TranMetal 60 FILE erase.bmp
GROUP PoorMetal 50 FILE erase.bmp
GROUP NonMetal 40 FILE erase.bmp
GROUP NobleGas 30 FILE erase.bmp
GROUP Alkali 20 FILE erase.bmp
GROUP AlkaliEarth 10 FILE erase.bmp
GROUP Misc 0 FILE erase.bmp

// *********************MISC*******************

// Fire
Element Misc Fire 255 0 0 -600 1 1 1 2000 Fire2 0 TEXT Fire
Element None Fire2 255 160 60 -400 1 1 1 2000 Clear 0 TEXT Fire2
