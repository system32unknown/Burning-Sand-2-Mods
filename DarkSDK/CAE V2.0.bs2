ON WhitezTrigger DRAW ELEMENT:Redz FILLEDRECT 295 95 10 10
ON WhitezTrigger DRAW ELEMENT:Greenz FILLEDRECT 84 95 10 10
ON WhitezTrigger DRAW ELEMENT:Bluez FILLEDRECT 84 315 10 10

TRIGGER ThermiteMaker {
DRAW ELEMENT:Clear OBJECT (X - 10) (Y - 12) m ELEMENT:Magnesium a ELEMENT:Aluminum r ELEMENT:Rust p ELEMENT:Plant f ELEMENT:Burner e ELEMENT:Wall {
	"eeeeeeeeee"
        "eaaaaaaaae"
        "eaaaaaaaae"
        "eaaaaaaaae"
        "eapppppppe"
        "efpppppppe"
        "errrrrrmme"
        "errrrrrmme"
        "errrrrrmme"
        "errrrrrmme"
        "errrrrrmme"
        "eeeeeeeeee"
        }
}

TRIGGER Cannons {
DRAW ELEMENT:Clear OBJECT (X - 15) (Y - 20) w ELEMENT:Wall s ELEMENT:Sodium c ELEMENT:Cant {
	"     ccccc     "
        "    ccccccc    "
        "   ccccccccc   "
        "   wcccccccw   "
        "   wwcccccww   "
        "   wswwwwwsw   "
        "   wsswwwssw   "
        "   wssswsssw   "
        "  wwsssssssww  "
        " wwwssssssswww "
        "wwwssssssssswww"
        "wwwssssssssswww"
        "wwwssssssssswww"
        "wwwssssssssswww"
        "wwwssssssssswww"
        "wwwssssssssswww"
        "wwwssssssssswww"
        "wwwssssssssswww"
        "wwwssssssssswww"
        "wwwwwwwwwwwwwww"
        }
}

TRIGGER ArtExplosion {
	DRAW 0 FILLEDCIRCLE X1 Y1 (0 RAND 20)
	FOR RayCount FROM 1 TO $1 DO ArtExplosion2 (X1 * 300) (Y1 * 300) ((0 - $6) RAND $6) ((0 - $5) RAND $5) ($3 RAND $4) $0 $2
}

TRIGGER ArtExplosion2 {
	DRAW $5 FILLEDCIRCLE ($0 / 300) ($1 / 300) $6
	IF ($4 > 0) <TIMER 1 FRAMES ArtExplosion2 ($0 - $3) ($1 - $2) ($2 - 1) $3 ($4 - 1) $5 $6>
}

REMOVETRIGGER Superb
ON Superb DRAW ELEMENT:Fire2 FILLEDCIRCLE X1 (Y - 1) 15

REMOVETRIGGER dalll
ON dalll DRAW ELEMENT:waveD FILLEDCIRCLE ((((X1 / 9) * 9) / 9) * 9) ((((Y1 / 9) * 9) / 9) * 9) 1

REMOVETRIGGER nuke
ON nuke DRAW ELEMENT:Whitee FILLEDCIRCLE X1 Y1 (2 RAND RADIUS)

REMOVETRIGGER growwed 
ON growwed DRAW ELEMENT:Whitee FILLEDCIRCLE X1 Y1 (2 RAND RADIUS)

REMOVETRIGGER nuke2
ON nuke2 DRAW ELEMENT:Redd FILLEDCIRCLE X1 Y1 (2 RAND RADIUS)

REMOVETRIGGER nuke3
ON nuke3 DRAW ELEMENT:Yelloww FILLEDCIRCLE X1 Y1 (2 RAND RADIUS)

REMOVETRIGGER nuke4
ON nuke4 DRAW ELEMENT:Nulledd FILLEDCIRCLE X1 Y1 (2 RAND RADIUS)

ON DRAW IF (((BUTTON == 1) || PREVIEW) && (ELEMENT1 == ELEMENT:BS2Crash)) <EXEC clearall>

REMOVETRIGGER eek
ON eek DRAW ELEMENT:AHH FILL 1 1 40 40
ON eek DRAW ELEMENT:AHH FILL 200 200 20 20

