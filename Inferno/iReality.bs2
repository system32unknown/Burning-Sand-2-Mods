TRIGGER LeftMenu {
EXEC listgroups
// MENU LEFT ADD TEXT "" SEPERATOR 0 <>
MENU LEFT ADD TEXT "Stamp Autogens" File stamp.bmp {
          EXEC AutoGenSelection
          SETPIECES = 1
          }
MENU LEFT ADD TEXT "" SEPERATOR 0 <>
}

TRIGGER MOUSEMOVE {
IF (SETPIECES != 0) {
          SET CURSOR 2
          REMOVETRIGGER drawing
          }
IF ((SETPIECES == 0) && (USETOOL != 0)) {
          REMOVETRIGGER drawing
          IF (USETOOL == 1) <CURSOR = 0>
          IF (USETOOL == 2) <CURSOR = 2>
          IF (USETOOL == 3) <CURSOR = 7>
          }
}

ON DRAW IF (SETPIECES != 0) {
REMOVETRIGGER drawing
IF ((BUTTON == 1) || PREVIEW) {
          IF (SETPIECES == -1) <DRAW GRIDELEMENT FILLEDRECT ((X / BRUSHSIZE) * BRUSHSIZE) ((Y / BRUSHSIZE) * BRUSHSIZE) BRUSHSIZE BRUSHSIZE>
          IF (SETPIECES == 1) TreeGen
          IF (SETPIECES == 2) HouseGen
          IF (SETPIECES == 3) BatteryGen
          IF (SETPIECES == 4) CrystalGen
          IF (SETPIECES == 5) AirportGen
          IF (SETPIECES == 6) TurbineGen
          IF (SETPIECES == 7) HotplateGen
          IF (SETPIECES == 8) FissionPlantGen
          IF (SETPIECES == 9) DrillRigGen
          IF (SETPIECES == 10) SET SETPIECES 0
          IF (SETPIECES == 11) SET SETPIECES 0
          IF (SETPIECES == 12) SET SETPIECES 0
          IF (SETPIECES == 13) SET SETPIECES 0
          IF (SETPIECES == 14) SET SETPIECES 0
          IF (SETPIECES == 15) SET SETPIECES 0
          IF (SETPIECES == 16) SET SETPIECES 0
          IF (SETPIECES == 17) SET SETPIECES 0
          IF (SETPIECES == 18) SET SETPIECES 0
          IF (SETPIECES == 19) SET SETPIECES 0
          IF (SETPIECES == 20) SET SETPIECES 0
          IF (SETPIECES == 21) SET SETPIECES 0
          IF (SETPIECES == 22) SET SETPIECES 0
          IF (SETPIECES == 23) SET SETPIECES 0
          }
}

ON DRAW IF ((SETPIECES == 0) && (USETOOL != 0)) {
IF (BUTTON == 1) {
          IF (USETOOL == 1) RepeatClick
          IF (USETOOL == 3) {
                    IF (CTRL) <ELEMENT1 = 1>
                    }
          }
IF (BUTTON == 2) {
          }
IF (BUTTON == 4) {
          }
}

TRIGGER MOUSEDOWN {
IF ((SETPIECES == 0) && (USETOOL != 0)) {
IF (BUTTON == 1) {
          IF (USETOOL == 1) ClickOnce
          IF (USETOOL == 2) LaserFire
          IF (USETOOL == 3) {
                    IF (ZOOM < 10) {
                              IF (CTRL == 0) {
                                        INC ZOOM
                                        ON zoominc SCROLL (X * ZOOM) (Y * ZOOM)
                                        }
                              }
                    }
          }
IF (BUTTON == 4) {
          IF (USETOOL == 3) <ZOOM = 1>
          }
}
}

TRIGGER ToolSelection {
MENU SUB CLEAR
MENU SUB ADD TEXT "Controls" File hand.bmp <USETOOL = 1>
IF (LaserX > 0) MENU SUB ADD TEXT "Fire Laser" File preview.bmp <USETOOL = 2>
MENU SUB ADD TEXT "Zoom" File zoom.bmp <USETOOL = 3>
SUBMENU
}

TRIGGER AutoGenSelection {
MENU RIGHT CLEAR

MENU RIGHT ADD TEXT "Element" ELEMENT ELEMENT:Earth {
          MENU SUB CLEAR
          MENU SUB ADD TEXT "Clear" ELEMENT ELEMENT:Clear SETGRIDELEMENT ELEMENT:Clear
          MENU SUB ADD TEXT "Earth" ELEMENT ELEMENT:Earth SETGRIDELEMENT ELEMENT:Earth
          MENU SUB ADD TEXT "Wall" ELEMENT ELEMENT:Wall SETGRIDELEMENT ELEMENT:Wall
          MENU SUB ADD TEXT "Water" ELEMENT ELEMENT:Water SETGRIDELEMENT ELEMENT:Water
          SUBMENU
          }
MENU RIGHT ADD TEXT "Tree" File tree.bmp <SET SETPIECES 1>
MENU RIGHT ADD TEXT "House" File home.bmp <SET SETPIECES 2>
MENU RIGHT ADD TEXT "Battery" ELEMENT ELEMENT:Battery <SETPIECES = 3>
MENU RIGHT ADD TEXT "Crystal Reactor" File http://www.freewebs.com/alchemygod/CrystalReactor.bmp <SETPIECES = 4>
MENU RIGHT ADD TEXT "Airport" ELEMENT ELEMENT:DummyElement3 <SETPIECES = 5>
MENU RIGHT ADD TEXT "Turbine" ELEMENT ELEMENT:Turbine <SETPIECES = 6>
MENU RIGHT ADD TEXT "HotPlate" ELEMENT ELEMENT:HeatPad <SETPIECES = 7>
MENU RIGHT ADD TEXT "Fission Reactor" ELEMENT ELEMENT:Uranium-238 <SETPIECES = 8>
MENU RIGHT ADD TEXT "Oil Rig" ELEMENT ELEMENT:Driller <SETPIECES = 9>
}

TRIGGER ClickOnce {
OVERELEMENT = (X PIXEL Y)
IF (OVERELEMENT == ELEMENT:SwitchOff) <DRAW ELEMENT:SwitchOn FILL X Y>
IF (OVERELEMENT == ELEMENT:SwitchOn) <DRAW ELEMENT:SwitchOff FILL X Y>
IF (OVERELEMENT == ELEMENT:ElecFountain) <DRAW ELEMENT:ElecFountain2 FILL X Y>
IF (OVERELEMENT == ELEMENT:ElecOilsource) <DRAW ELEMENT:ElecOilsource2 FILL X Y>
IF (OVERELEMENT == ELEMENT:ElecBurner) <DRAW ELEMENT:ElecBurner2 FILL X Y>
IF (OVERELEMENT == ELEMENT:HeatPad) <DRAW ELEMENT:HeatPad2 FILL X Y>
}

TRIGGER RepeatClick {
OVERELEMENT = (X PIXEL Y)
IF (OVERELEMENT == ELEMENT:Water) <DRAW ELEMENT:Steam REPLACEFILLEDCIRCLE X Y 2 0 ELEMENT:Water>
IF (OVERELEMENT == ELEMENT:Earth) <DRAW ELEMENT:Wall REPLACEFILLEDCIRCLE X Y 2 0 ELEMENT:Earth>
IF (OVERELEMENT == ELEMENT:Acid) <DRAW ELEMENT:Oil REPLACEFILLEDCIRCLE X Y 2 0 ELEMENT:Acid>
IF (OVERELEMENT == ELEMENT:Clear) <DRAW ELEMENT:Fire POINT X Y>
IF (OVERELEMENT == ELEMENT:Metal) <DRAW ELEMENT:HotMetal REPLACEFILLEDCIRCLE X Y 2 0 ELEMENT:Metal>
}

// Auto Gens

TRIGGER SETGRIDELEMENT {
SETPIECES = -1
GRIDELEMENT = $0
MENU REFRESH
}


TRIGGER TreeGen {
DRAW ELEMENT:Wood FILLEDRECT (X - 2) (Y - 15) 5 19
DRAW ELEMENT:Plant FILLEDCIRCLE (X - 4) (Y - 19) 9
DRAW ELEMENT:Plant FILLEDCIRCLE (X + 4) (Y - 19) 9
DRAW ELEMENT:Plant FILLEDCIRCLE X (Y - 25) 9
}

