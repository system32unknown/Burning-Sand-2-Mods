InteractionTrigger Parasite Clear { 20%
CLOSEST ELEMENT:Plant X1 Y1 50
IF ((CLOSESTX > 0) && (CLOSESTY > 0)) { 
IF ((CLOSESTX > X1) && (X2 > X1)) <DRAW 0 SWAPPOINTS X2 Y2 X1 Y1>
IF ((CLOSESTX < X1) && (X2 < X1)) <DRAW 0 SWAPPOINTS X2 Y2 X1 Y1>
IF ((CLOSESTY > Y1) && (Y2 > Y1)) <DRAW 0 SWAPPOINTS X2 Y2 X1 Y1>
IF ((CLOSESTY < Y1) && (Y2 < Y1)) <DRAW 0 SWAPPOINTS X2 Y2 X1 Y1>
}
CLOSEST ELEMENT:Wood X1 Y1 50
IF ((CLOSESTX > 0) && (CLOSESTY > 0)) { 
IF ((CLOSESTX > X1) && (X2 > X1)) <DRAW 0 SWAPPOINTS X2 Y2 X1 Y1>
IF ((CLOSESTX < X1) && (X2 < X1)) <DRAW 0 SWAPPOINTS X2 Y2 X1 Y1>
IF ((CLOSESTY > Y1) && (Y2 > Y1)) <DRAW 0 SWAPPOINTS X2 Y2 X1 Y1>
IF ((CLOSESTY < Y1) && (Y2 < Y1)) <DRAW 0 SWAPPOINTS X2 Y2 X1 Y1>
}
}

