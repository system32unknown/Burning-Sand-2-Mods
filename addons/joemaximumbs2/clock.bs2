Element none ClockWater ELEMENTB:Water (255 - ELEMENTG:Water) ELEMENTR:Water
Interaction ClockWater Clear ClockWater Water 2%

Element none ClockSand ELEMENTB:Sand (255 - ELEMENTG:Sand) ELEMENTR:Sand
Interaction ClockSand Clear ClockSand Sand 2%

Element none ClockVulcano ELEMENTB:Vulcano (255 - ELEMENTG:Vulcano) ELEMENTR:Vulcano
Interaction ClockVulcano Clear ClockVulcano Vulcano 2%

Element none ClockSeed ELEMENTB:Seed (255 - ELEMENTG:Seed) ELEMENTR:Seed
Interaction ClockSeed Clear ClockSeed Seed 2%

Element none ClockParasite ELEMENTB:Parasite (255 - ELEMENTG:Parasite) ELEMENTR:Parasite
Interaction ClockParasite Clear ClockParasite Parasite 2%

Element none ClockSteam ELEMENTB:Steam (255 - ELEMENTG:Steam) ELEMENTR:Steam
Interaction ClockSteam Clear ClockSteam Steam 2%

Element none ClockGas ELEMENTB:Gas (255 - ELEMENTG:Gas) ELEMENTR:Gas
Interaction ClockGas Clear ClockGas Gas 2%

Element none ClockGasII ELEMENTB:GasII (255 - ELEMENTG:GasII) ELEMENTR:GasII
Interaction ClockGasII Clear ClockGasII GasII 2%

Element none ClockComet ELEMENTB:Comet (255 - ELEMENTG:Comet) ELEMENTR:Comet
Interaction ClockComet Clear ClockComet Comet 2%

Element none ClockStone ELEMENTB:Stone (255 - ELEMENTG:Stone) ELEMENTR:Stone
Interaction ClockStone Clear ClockStone Stone 2%

TRIGGER initVAR {
	txtsize = 60
	txtelement = ELEMENT:Burner
	txtY = txtsize
	txtX = 5
	drawBorder = 0
	clockspeed = 1
	showsecond = 1
	isTOP = 1
	isBOTTOM = 0
	lastWIDTH = 0
	ClockPos = 1
	Analog = 0
	
	INCLUDE clock.sav
}

TRIGGER newmenutop EXTENDS menutop {
	MENU TOP ADD TEXT "Clock" ELEMENT ELEMENT:Bidon menuClock
}

TRIGGER menuClock {
	MENU SUB CLEAR
	MENU SUB ADD TEXT "Mode" ELEMENT ELEMENT:eMode {
		MENU SUB CLEAR
		MENU SUB ADD TEXT "Digital" ELEMENT ELEMENT:eModeDigital <Analog = 0)
		MENU SUB ADD TEXT "Analog" ELEMENT ELEMENT:eModeAnalog <Analog = 1)
		SUBMENU
	}	
	MENU SUB ADD TEXT "Size >" ELEMENT ELEMENT:eSize {
		MENU SUB CLEAR
		MENU SUB ADD TEXT "Small" ELEMENT ELEMENT:eSizesmall ChangeClockSize 30
		MENU SUB ADD TEXT "Medium" ELEMENT ELEMENT:eSizemedium ChangeClockSize 60
		MENU SUB ADD TEXT "Large" ELEMENT ELEMENT:eSizebig ChangeClockSize 90
		SUBMENU
	}
	MENU SUB ADD TEXT "Position >" ELEMENT ELEMENT:ePosition menuPosition
	MENU SUB ADD TEXT "Element >" ELEMENT ELEMENT:hexElement menuElement
	MENU SUB ADD TEXT "Refresh Rate >" ELEMENT ELEMENT:RR menuRefreshrate
	MENU SUB ADD TEXT "Border >" ELEMENT ELEMENT:Border {
		MENU SUB CLEAR
		MENU SUB ADD TEXT "ON" ELEMENT ELEMENT:BorderON  drawBorderFunction 1
		MENU SUB ADD TEXT "OFF" ELEMENT ELEMENT:BorderOFF drawBorderFunction 0
		SUBMENU	
	}
	MENU SUB ADD TEXT "Second >" ELEMENT ELEMENT:Second {
		MENU SUB CLEAR
		MENU SUB ADD TEXT "ON" ELEMENT ELEMENT:SecondON <SET showsecond 1>
		MENU SUB ADD TEXT "OFF" ELEMENT ELEMENT:SecondOFF <SET showsecond 0>
		SUBMENU
	}
	SUBMENU
}

TRIGGER drawBorderFunction {
	EXEC REPLACEFILLEDRECT ELEMENT:Clear txtelement (lastX - 1) (lastY - txtsize + 5) (lastWIDTH + 2) (lastsize + 2)
	drawBorder = $0
}

TRIGGER menuElement {
	MENU SUB CLEAR
	MENU SUB ADD TEXT "Burner" ELEMENT ELEMENT:Burner <SET txtelement ELEMENT:Burner>
	MENU SUB ADD TEXT "Earth" ELEMENT ELEMENT:Earth <SET txtelement ELEMENT:Earth>
	MENU SUB ADD TEXT "Water" ELEMENT ELEMENT:Water <SET txtelement ELEMENT:ClockWater>
	MENU SUB ADD TEXT "Sand" ELEMENT ELEMENT:Sand <SET txtelement ELEMENT:ClockSand>
	MENU SUB ADD TEXT "Vulcano" ELEMENT ELEMENT:Vulcano <SET txtelement ELEMENT:ClockVulcano>
	MENU SUB ADD TEXT "Seed" ELEMENT ELEMENT:Seed <SET txtelement ELEMENT:ClockSeed>
	MENU SUB ADD TEXT "Parasite" ELEMENT ELEMENT:Parasite <SET txtelement ELEMENT:ClockParasite>
	MENU SUB ADD TEXT "Steam" ELEMENT ELEMENT:Steam <SET txtelement ELEMENT:ClockSteam>
	MENU SUB ADD TEXT "Gas" ELEMENT ELEMENT:Gas <SET txtelement ELEMENT:ClockGas>
	MENU SUB ADD TEXT "GasII" ELEMENT ELEMENT:GasII <SET txtelement ELEMENT:ClockGasII>
	MENU SUB ADD TEXT "Stone" ELEMENT ELEMENT:Stone <SET txtelement ELEMENT:ClockStone>
	MENU SUB ADD TEXT "Comet" ELEMENT ELEMENT:Comet <SET txtelement ELEMENT:ClockComet>
	SUBMENU
}

TRIGGER menuRefreshrate {
	MENU SUB CLEAR
	MENU SUB ADD TEXT "1 Frame" ELEMENT ELEMENT:RR1 <SET clockspeed 1>
	MENU SUB ADD TEXT "10 Frames" ELEMENT ELEMENT:RR10 <SET clockspeed 10>
	MENU SUB ADD TEXT "60 Frames" ELEMENT ELEMENT:RR60 <SET clockspeed 60>
	MENU SUB ADD TEXT "120 Frames" ELEMENT ELEMENT:RR120 <SET clockspeed 120>
	MENU SUB ADD TEXT "240 Frames" ELEMENT ELEMENT:RR240 <SET clockspeed 240>
	MENU SUB ADD TEXT "480 Frames" ELEMENT ELEMENT:RR480 <SET clockspeed 480>
	MENU SUB ADD TEXT "960 Frames" ELEMENT ELEMENT:RR960 <SET clockspeed 960>
	SUBMENU
}

TRIGGER menuPosition {
	MENU SUB CLEAR
	IF (ClockPos == 1) <MENU SUB ADDBORDER TEXT "Top Left" ELEMENT ELEMENT:ePositionTL 255 255 255 SetNewPosition 5 (txtsize + 5) 1 0 1> ELSE <MENU SUB ADD TEXT "Top Left" ELEMENT ELEMENT:ePositionTL SetNewPosition 5 (txtsize + 5) 1 0 1>
	IF (ClockPos == 2) <MENU SUB ADDBORDER TEXT "Top Right" ELEMENT ELEMENT:ePositionTR 255 255 255 SetNewPosition (WIDTH - totalWIDTH - 5) (txtsize + 5) 1 0 2> ELSE <MENU SUB ADD TEXT "Top Right" ELEMENT ELEMENT:ePositionTR SetNewPosition (WIDTH - totalWIDTH - 5) (txtsize + 5) 1 0 2>
	IF (ClockPos == 3) <MENU SUB ADDBORDER TEXT "Bottom Left" ELEMENT ELEMENT:ePositionBL 255 255 255 SetNewPosition 5 (HEIGHT - 10) 0 1 3> ELSE <MENU SUB ADD TEXT "Bottom Left" ELEMENT ELEMENT:ePositionBL SetNewPosition 5 (HEIGHT - 10) 0 1 3>
	IF (ClockPos == 4) <MENU SUB ADDBORDER TEXT "Bottom Right" ELEMENT ELEMENT:ePositionBR 255 255 255 SetNewPosition (WIDTH - totalWIDTH - 5) (HEIGHT - 10) 0 1 4> ELSE <MENU SUB ADD TEXT "Bottom Right" ELEMENT ELEMENT:ePositionBR SetNewPosition (WIDTH - totalWIDTH - 5) (HEIGHT - 10) 0 1 4>
	IF (ClockPos == 5) <MENU SUB ADDBORDER TEXT "Center" ELEMENT ELEMENT:ePositionC 255 255 255 SetNewPosition ((WIDTH - totalWIDTH) / 2) (((HEIGHT / 2) + (totalHEIGHT / 2)) - 5) 0 0 5> ELSE <MENU SUB ADD TEXT "Center" ELEMENT ELEMENT:ePositionC SetNewPosition ((WIDTH - totalWIDTH) / 2) (((HEIGHT / 2) + (totalHEIGHT / 2)) - 5) 0 0 5>
	SUBMENU
}

TRIGGER SetNewPosition {
	EXEC REPLACEFILLEDRECT ELEMENT:Clear txtelement (lastX - 1) (lastY - txtsize + 5) (lastWIDTH + 2) (lastsize + 2)
	txtX = $0
	txtY = $1
	isTOP = $2
	isBOTTOM = $3
	ClockPos = $4
}

TRIGGER writetime {
	IF (Analog == 0) {
		EXEC updatetotalWIDTH
		EXEC WriteDigitalTime
	}
	IF (Analog == 1) WriteAnalogClock
	// MAKE THIS A LOOP, AT CHOSEN REFRESH RATE
	TIMER clockspeed FRAMES writetime	
}

TRIGGER WriteAnalogClock {
	aSize = BRUSHSIZE
	EXEC GetHourAngle HOUR
	EXEC REPLACEFILLEDRECT ELEMENT:Clear ELEMENT:Earth 0 0 WIDTH HEIGHT
	FOR i FROM 1 TO 12 DO {
		EXEC GetHourAngle i
		DRAW ELEMENT:Earth LINE (100 + (((SIN (AngleFOUND * 1000)) * (23 * aSize)) / 1000)) (100 + (((COS (AngleFOUND * 1000)) * (23 * aSize)) / 1000)) (((SIN (AngleFOUND * 1000)) * (2 * aSize)) / 1000) (((COS (AngleFOUND * 1000)) * (2 * aSize)) / 1000)
		WRITE ELEMENT:Earth (100 + (((SIN (AngleFOUND * 1000)) * (20 * aSize)) / 1000)) (100 + (((COS (AngleFOUND * 1000)) * (20 * aSize)) / 1000)) 8 CENTER NUMBER i
	}
	DRAW ELEMENT:Earth CIRCLE 100 100 (25 * aSize)
	DRAW ELEMENT:Earth LINE 100 100 (((SIN (AngleFOUND * 1000)) * (15 * aSize)) / 1000) (((COS (AngleFOUND * 1000)) * (15 * aSize)) / 1000)
	EXEC GetMinSecAngle 1
	DRAW ELEMENT:Earth LINE 100 100 (((SIN (AngleFOUND * 1000)) * (23 * aSize)) / 1000) (((COS (AngleFOUND * 1000)) * (23 * aSize)) / 1000)
	EXEC GetMinSecAngle 0
	DRAW ELEMENT:Earth LINE 100 100 (((SIN (AngleFOUND * 1000)) * (18 * aSize)) / 1000) (((COS (AngleFOUND * 1000)) * (18 * aSize)) / 1000)	
}

TRIGGER GetHourAngle {
	IF ($0 >= 13) <newHOUR = ($0 - 12)> ELSE <newHOUR = $0>
	
	IF (newHOUR == 1) <AngleFOUND = 150>
	IF (newHOUR == 2) <AngleFOUND = 120>
	IF (newHOUR == 3) <AngleFOUND = 90>
	IF (newHOUR == 4) <AngleFOUND = 60>
	IF (newHOUR == 5) <AngleFOUND = 30>
	IF (newHOUR == 6) <AngleFOUND = 360>
	IF (newHOUR == 7) <AngleFOUND = 330>
	IF (newHOUR == 8) <AngleFOUND = 300>
	IF (newHOUR == 9) <AngleFOUND = 270>
	IF (newHOUR == 10) <AngleFOUND = 240>
	IF (newHOUR == 11) <AngleFOUND = 210>
	IF (newHOUR == 12) <AngleFOUND = 180>
}

TRIGGER GetMinSecAngle {
	IF ($0 == 1) <newHOUR = MINUTE> ELSE <newHOUR = SECOND>
	
	IF (newHOUR == 0) <AngleFOUND = 180>
	IF (newHOUR == 1) <AngleFOUND = 174>
	IF (newHOUR == 2) <AngleFOUND = 168>
	IF (newHOUR == 3) <AngleFOUND = 162>
	IF (newHOUR == 4) <AngleFOUND = 156>
	IF (newHOUR == 5) <AngleFOUND = 150>
	IF (newHOUR == 6) <AngleFOUND = 144>
	IF (newHOUR == 7) <AngleFOUND = 138>
	IF (newHOUR == 8) <AngleFOUND = 132>
	IF (newHOUR == 9) <AngleFOUND = 126>
	IF (newHOUR == 10) <AngleFOUND = 120>
	IF (newHOUR == 11) <AngleFOUND = 114>
	IF (newHOUR == 12) <AngleFOUND = 108>
	IF (newHOUR == 13) <AngleFOUND = 102>
	IF (newHOUR == 14) <AngleFOUND = 96>
	IF (newHOUR == 15) <AngleFOUND = 90>
	IF (newHOUR == 16) <AngleFOUND = 84>
	IF (newHOUR == 17) <AngleFOUND = 78>
	IF (newHOUR == 18) <AngleFOUND = 72>
	IF (newHOUR == 19) <AngleFOUND = 66>
	IF (newHOUR == 20) <AngleFOUND = 60>
	IF (newHOUR == 21) <AngleFOUND = 54>
	IF (newHOUR == 22) <AngleFOUND = 48>
	IF (newHOUR == 23) <AngleFOUND = 42>
	IF (newHOUR == 24) <AngleFOUND = 36>
	IF (newHOUR == 25) <AngleFOUND = 30>
	IF (newHOUR == 26) <AngleFOUND = 24>
	IF (newHOUR == 27) <AngleFOUND = 18>
	IF (newHOUR == 28) <AngleFOUND = 12>
	IF (newHOUR == 29) <AngleFOUND = 6>
	IF (newHOUR == 30) <AngleFOUND = 360>
	IF (newHOUR == 31) <AngleFOUND = 354>
	IF (newHOUR == 32) <AngleFOUND = 348>
	IF (newHOUR == 33) <AngleFOUND = 342>
	IF (newHOUR == 34) <AngleFOUND = 336>
	IF (newHOUR == 35) <AngleFOUND = 330>
	IF (newHOUR == 36) <AngleFOUND = 324>
	IF (newHOUR == 37) <AngleFOUND = 318>
	IF (newHOUR == 38) <AngleFOUND = 312>
	IF (newHOUR == 39) <AngleFOUND = 306>
	IF (newHOUR == 40) <AngleFOUND = 300>
	IF (newHOUR == 41) <AngleFOUND = 294>
	IF (newHOUR == 42) <AngleFOUND = 288>
	IF (newHOUR == 43) <AngleFOUND = 282>
	IF (newHOUR == 44) <AngleFOUND = 276>
	IF (newHOUR == 45) <AngleFOUND = 270>
	IF (newHOUR == 46) <AngleFOUND = 264>
	IF (newHOUR == 47) <AngleFOUND = 258>
	IF (newHOUR == 48) <AngleFOUND = 252>
	IF (newHOUR == 49) <AngleFOUND = 246>
	IF (newHOUR == 50) <AngleFOUND = 240>
	IF (newHOUR == 51) <AngleFOUND = 234>
	IF (newHOUR == 52) <AngleFOUND = 228>
	IF (newHOUR == 53) <AngleFOUND = 222>
	IF (newHOUR == 54) <AngleFOUND = 216>
	IF (newHOUR == 55) <AngleFOUND = 210>	
	IF (newHOUR == 56) <AngleFOUND = 204>	
	IF (newHOUR == 57) <AngleFOUND = 198>
	IF (newHOUR == 58) <AngleFOUND = 192>
	IF (newHOUR == 59) <AngleFOUND = 186>
}

BRUSHSIZE = 1

TRIGGER WriteDigitalTime {
	// CLEAR THE LAST CLOCK
	EXEC REPLACEFILLEDRECT ELEMENT:Clear txtelement (lastX - 1) (lastY - txtsize + 5) (lastWIDTH + 2) (lastsize + 2)
	
	// MAKE THIS A 12 HOURS CLOCK
	IF (HOUR >= 13) <SET newHOUR (HOUR - 12)> ELSE <SET newHOUR HOUR>
	
	// DRAW A BORDER IF ON, DEPENDING ON THE SIZE OF THE CLOCK
	IF ((drawBorder == 1) && (txtsize == 30)) <DRAW txtelement RECT (txtX - 1) (txtY - txtsize) (totalWIDTH + 1) (txtsize + 2)>
	IF ((drawBorder == 1) && (txtsize > 30)) <DRAW txtelement RECT (txtX - 1) (txtY - txtsize + 5) (totalWIDTH + 1) (txtsize + 1)>
	
	// WRITE THE HOURS, IF ITS LESS THAN 10, ADD A "0" BEFORE
	IF (newHOUR < 10)) {
		WRITE txtelement txtX txtY txtsize TEXT "0"
		WRITE txtelement (txtX + charWIDTH) txtY txtsize NUMBER newHOUR
	} ELSE {
		WRITE txtelement txtX txtY txtsize NUMBER newHOUR
	}
	
	// WRITE THE FIRST ":"
	WRITE txtelement (txtX + (charWIDTH * 2) + (charWIDTH / 3)) txtY txtsize TEXT ":"
	
	// WRITE THE MINUTE, IF ITS LESS THAN 10, ADD A "0" BEFORE
	IF (MINUTE < 10) {
		WRITE txtelement (txtX + (charWIDTH * 3)) txtY txtsize TEXT "0"
		WRITE txtelement (txtX + (charWIDTH * 4)) txtY txtsize NUMBER MINUTE
	} ELSE {
		WRITE txtelement (txtX + (charWIDTH * 3)) txtY txtsize NUMBER MINUTE
	}
	
	// IF THE SECOND IS ON, MAKE SAME THING AS OTHER BUT ADD THE SECODND ":" FIRST
	IF (showsecond == 1) {
		WRITE txtelement (txtX + (charWIDTH * 5) + (charWIDTH / 3)) txtY txtsize TEXT ":"
		IF ((showsecond == 1) && (SECOND < 10)) {
			WRITE txtelement (txtX + (charWIDTH * 6)) txtY txtsize TEXT "0"
			WRITE txtelement (txtX + (charWIDTH * 7)) txtY txtsize NUMBER SECOND
		} ELSE {
			WRITE txtelement (txtX + (charWIDTH * 6)) txtY txtsize NUMBER SECOND
		}
	}
	
	// SET THE NEW CLOCK COORDINATES
	lastWIDTH = totalWIDTH
	lastX = txtX
	lastY = txtY
	lastsize = txtsize
}

// THIS CALCULATE THE TOTAL WIDTH OF THE CLOCK WRITE "00:00" TEMPLATE USING CLEAR ELEMENT
TRIGGER updatetotalWIDTH {
	WRITE ELEMENT:Clear txtX txtY txtsize TEXT "0"
	charWIDTH = WRITEWIDTH
	IF (showsecond == 1) <SET totalWIDTH ((charWIDTH * 8) + 5)>
	IF (showsecond == 0) <SET totalWIDTH ((charWIDTH * 5) + 5)>
	IF (txtsize == 30) <SET totalHEIGHT (txtsize + 3)>
	IF (txtsize > 30) <SET totalHEIGHT (txtsize + 2)>
}

TRIGGER ChangeClockSize {
	EXEC REPLACEFILLEDRECT ELEMENT:Clear txtelement (lastX - 1) (lastY - txtsize + 5) (lastWIDTH + 2) (lastsize + 2)
	txtsize = $0
	EXEC updatetotalWIDTH
	IF (isTOP == 1) <SET txtY (txtsize + 5)>
	IF (isTOP == 1) <SET txtX 5>
	IF (isBOTTOM == 1) <SET txtY (HEIGHT - 10)>
	IF (isBOTTOM == 1) <SET txtX (WIDTH - totalWIDTH - 5)>
	IF ((isTOP == 0) && (isBOTTOM == 0)) <SET txtX ((WIDTH - totalWIDTH) / 2)>
	IF ((isTOP == 0) && (isBOTTOM == 0)) <SET txtY (((HEIGHT / 2) + (totalHEIGHT / 2)) - 5)>
}

TRIGGER QUIT {
	FILE DELETE clock.sav
	FILE OPEN clock.sav
	
	SAVE VAR txtsize txtsize
	SAVE VAR txtelement txtelement
	SAVE VAR txtY txtY
	SAVE VAR txtX txtX
	SAVE VAR drawBorder drawBorder
	SAVE VAR clockspeed clockspeed
	SAVE VAR showsecond showsecond
	SAVE VAR isTOP isTOP
	SAVE VAR isBOTTOM isBOTTOM
	SAVE VAR lastWIDTH lastWIDTH
	SAVE VAR ClockPos ClockPos
	SAVE VAR Analog Analog
	
	FILE CLOSE
	EXIT
}

ON menutop EXEC newmenutop
ON clearscreensandbox EXEC writetime txtX txtY txtelement txtsize

EXEC clearscreensandbox 0
EXEC initVAR
EXEC menutop
EXEC writetime txtX txtY txtelement txtsize