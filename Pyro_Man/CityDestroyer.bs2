TRIGGER UFOEXE {
EXEC UFOGUN X1 Y1 (10 RAND 50)
N = 25
}
TRIGGER C4 {
Element None C1 (1 RAND 255) (1 RAND 255) (1 RAND 255)
Element None C2 (1 RAND 255) (1 RAND 255) (1 RAND 255)
Element None C3 (1 RAND 255) (1 RAND 255) (1 RAND 255)
Element None C5 (1 RAND 255) (1 RAND 255) (1 RAND 255)
Element None C6 (1 RAND 255) (1 RAND 255) (1 RAND 255)
Element None C7 (1 RAND 255) (1 RAND 255) (1 RAND 255)
Element None C8 (1 RAND 255) (1 RAND 255) (1 RAND 255)
Element None C9 (1 RAND 255) (1 RAND 255) (1 RAND 255)
Element None C10 (1 RAND 255) (1 RAND 255) (1 RAND 255)
TIMER 100 FRAMES C4
}
EXEC C4
TRIGGER UFOGUN {
DRAW ELEMENT:Green FILLEDRECT ($0 - 20) $1 20 ((HEIGHT - $1) / N)
DRAW ELEMENT:Green RECT ($0 - 20) $1 20 ((HEIGHT - $1) / N)
IF (N > 0) <N = (N - 1)>
IF (N > 0) <TIMER 5 FRAMES UFOGUN $0 $1>
IF (N == 0) <TIMER 100 FRAMES GUTS>
}

TRIGGER CLEARALL2 { 
TRIANGLE ELEMENT:ClearAll2 X1 Y1 (X1 - 10) Y1 X1 (Y1 - 10)
TRIANGLE ELEMENT:Clear (X1 - 1) Y1 (X1 - 11) Y1 (X1 - 1) (Y1 - 10)
}
TRIGGER NUKEEXE {
EXEC NUKE X1 Y1
}

TRIGGER DUMBBOMBEXE {
EXEC DUMBBOMBDROP X1 Y1
}
TRIGGER DUMBBOMBDROP {
IF (($0 PIXEL ($1 + 6)) == Clear) <EXEC DUMBBOMB $0 ($1 + 6)>
IF (($0 PIXEL ($1 + 6)) == Clear) <TIMER 1 FRAMES DUMBBOMBDROP $0 ($1 + 6)>
IF ((($0 PIXEL ($1 + 6)) != Clear) && (($0 PIXEL ($1 + 6)) != Shock2)) <EXEC NUKESHOCK 1 1 $0 $1 205 ELEMENT:FIRE>
IF ((($0 PIXEL ($1 + 6)) != Clear) && (($0 PIXEL ($1 + 6)) != Shock2)) <DRAW ELEMENT:Burner CIRCLE $0 $1 50>
}



TRIGGER Lightning {
IF ($0 == 0) <DRAW ELEMENT:Lightning2 LINE $1 $2 ($1 + 20) ($2 + 20)>
IF ($0 == 1) <DRAW ELEMENT:Lightning2 LINE $1 $2 ($1 - 20) ($2 - 20)>
IF (($0 == 0) && ($2 < HEIGHT)) <TIMER 1 FRAMES Lightning 1 ($1 + 20) ($2 + 20)>
IF ($0 == 1) <TIMER 1 FRAMES Lightning 0 ($1 - 20) $2>
}

TRIGGER Clear2 {
Element None Clear2 125 125 255 (0 RAND 1000) (1 RAND 255) (1 RAND 255) (1 RAND 255) 
DRAW ELEMENT:Clear2 POINT X1 Y1 
}

TRIGGER NUKE {
IF (($0 PIXEL ($1 + 3)) == Clear) <EXEC NUKEDRAW $0 ($1 + 3)>
IF (($0 PIXEL ($1 + 3)) == Clear) <TIMER 1 FRAMES NUKE $0 ($1 + 3)>
IF ((($0 PIXEL ($1 + 3)) != Clear) && (($0 PIXEL ($1 + 3)) != Shock2)) <EXEC NUKEHIT $0 $1>
}
TRIGGER NUKEHIT {
EXEC NUKESHOCK 1 1 $0 $1 360 ELEMENT:SHOCK
}

TRIGGER NUKESHOCK {
DRAW $5 ELLIPSE $2 $3 $0 $1 
DRAW ELEMENT:BURNY FILLEDCIRCLE $2 $3 (1 RAND 35)
IF ($0 < $4) <TIMER 1 FRAMES NUKESHOCK ($0 + 4) ($1 + 2) $2 $3 $4 $5>
} 
TRIGGER BOMB {
DRAW ELEMENT:FIRE CIRCLE (X1 + 8) (Y1 + 8) 5 1
DRAW ELEMENT:Fire CIRCLE (X1 + 8) (Y1 + 8) 4 1
DRAW ELEMENT:Water CIRCLE (X1 + 8) (Y1 + 8) 3 1
DRAW ELEMENT:Grass CIRCLE (X1 + 8) (Y1 + 8) 2 1
DRAW ELEMENT:FIRE POINT (X1 + 8) (Y1 + 8)
}

TRIGGER CLEARALL {
DRAW ELEMENT:ClearAll FILLEDCIRCLE X1 Y1 10 10
DRAW ELEMENT:Clear FILLEDCIRCLE X1 Y1 9 9
}

TRIGGER BOOMER {
EXEC BOOMGROWyay X1 Y1 1
// x1 y1 radius
}
TRIGGER BOOMGROWyay {
DRAW ELEMENT:Sparkler CIRCLE $0 $1 $2
IF ($2 < 25) <TIMER 1 FRAMES BOOMGROWyay $0 $1 ($2 + 1)>
IF ($2 > 24) <EXEC BOOMSHRINKnoo $0 $1 $2>
}
TRIGGER BOOMSHRINKnoo {
DRAW ELEMENT:Sparkler CIRCLE $0 $1 $2
IF ($2 > 0) <TIMER 1 FRAMES BOOMSHRINK $0 $1 ($2 - 1)>
}
TRIGGER SPARKLER {
XN = ((COS (X1 ^ Y1)) * 1000)
XO = ((COS (Y1 ^ X1)) * 1000)
DRAW ELEMENT:BLUE LINE X1 Y1 XN XO
}

TRIGGER GUTS {
EXEC GUTS2 X1 Y1 5
}
TRIGGER GUTS2 {
IF ($2 < 40) <DRAW ELEMENT:FIRE FILLEDCIRCLE $0 ($1 + $2) 4>
IF ($2 < 40) <TIMER 3 FRAMES GUTS2 $0 $1 ($2 + 7)>
EXEC GUTQ
}
TRIGGER GUTQ {
XTMP = (0 RAND 7)
YTMP = (0 RAND 7)
RANDCHECK = (0 RAND 3)
RANDCHECK2 = (0 RAND 3)
IF ((RANDCHECK == 2) && (RANDCHECK2 == 2)) <EXEC GUT XTMP YTMP X1 Y1 1 (15 RAND 55) 1 ELEMENT:SUPERFIRE> 
IF ((RANDCHECK == 1) && (RANDCHECK2 == 2)) <EXEC GUT XTMP YTMP X1 Y1 2 (15 RAND 55) 1 ELEMENT:SUPERFIRE>
IF ((RANDCHECK == 1) && (RANDCHECK2 == 1)) <EXEC GUT XTMP YTMP X1 Y1 3 (15 RAND 55) 1 ELEMENT:SUPERFIRE>
IF ((RANDCHECK == 2) && (RANDCHECK2 == 1)) <EXEC GUT XTMP YTMP X1 Y1 4 (15 RAND 55) 1 ELEMENT:SUPERFIRE>
}
TRIGGER GUT {
IF ($4 == 1) <DRAW $7 FILLEDCIRCLE ($2 + $0) ($3 + $1) $6 $6>
IF ($4 == 2) <DRAW $7 FILLEDCIRCLE ($2 - $0) ($3 + $1) $6 $6>
IF ($4 == 3) <DRAW $7 FILLEDCIRCLE ($2 - $0) ($3 - $1) $6 $6>
IF ($4 == 4) <DRAW $7 FILLEDCIRCLE ($2 + $0) ($3 - $1) $6 $6>
STOPVAR3 = (STOPVAR3 + 1)
IF ((STOPVAR3 < $5) && ($4 == 1)) <TIMER 4 FRAMES GUT $0 $1 ($2 + $0) ($3 + $1) 1 $5 $6 $7>
IF ((STOPVAR3 < $5) && ($4 == 2)) <TIMER 4 FRAMES GUT $0 $1 ($2 - $0) ($3 + $1) 2 $5 $6 $7>
IF ((STOPVAR3 < $5) && ($4 == 3)) <TIMER 4 FRAMES GUT $0 $1 ($2 - $0) ($3 - $1) 3 $5 $6 $7>
IF ((STOPVAR3 < $5) && ($4 == 4)) <TIMER 4 FRAMES GUT $0 $1 ($2 + $0) ($3 - $1) 4 $5 $6 $7>
IF (STOPVAR3 > ($5 - 1)) <TIMER 3 FRAMES STOPAGAIN>
}
TRIGGER STOPAGAIN {
STOPVAR3 == 0
N == 25
}

TRIGGER Boom {
DRAW ELEMENT:Fire FILLEDCIRCLE X1 Y1 (25 RAND 80) 25
}

T = 1 
U = 0 

TRIGGER WHITEHOLE { 
IF (T == U) <EXEC WHITEHOLE2 X1 Y1> 
IF ((T > U) || ((U + 2) == T)) <EXEC LOCATION X1 Y1> 
} 

TRIGGER LOCATION { 
RANDX = ((50 RAND WIDTH) - 10))
RANDY = ((50 RAND HEIGHT) - 10))
IF (((WIDTH / 2) > RANDX) && (((WIDTH / 2) < RANDX))) <EXEC LOCATION> 
IF (((HEIGHT / 2) > RANDY) && ((HEIGHT / 2) < RANDY)) <EXEC LOCATION> 
IF (((WIDTH / 2) < RANDX) || ((WIDTH / 2) > RANDX)) <T = 2> 
IF (((HEIGHT / 2) < RANDY) || ((HEIGHT / 2) > RANDY)) <U = 2>  
IF (T == U) <EXEC WHITEHOLE2 X1 Y1> 
}
TRIGGER WHITEHOLE2 { 
CX = (1 RAND WIDTH)
CY = (1 RAND HEIGHT) 
DRAW 0 SWAPPOINTS $0 $1 CX CY 
IF (BLAH > 149) <TIMER 60 FRAMES RESETWHITE> 
}

TRIGGER RESETWHITE { 
T = 1 
U = 0 
BLAH = 0
}


TRIGGER SKINDARK {
DRAW ELEMENT:FIRE LINE X1 Y1 (X1 + 5) Y1
}

TRIGGER CyanideBurn {
DRAW ELEMENT:Cyanide2 FILLEDCIRCLE X1 Y1 2
}

InteractionTrigger GunPower FIRE { 10%
EXEC EXPLOSION X1 Y1
}
InteractionTrigger GunPower SUPERFIRE { 10%
EXEC EXPLOSION X1 Y1
}
InteractionTrigger Cyanide2 FIRE { 10%
EXEC EXPLOSION X1 Y1
}
InteractionTrigger Cyanide2 SUPERFIRE { 10%
EXEC EXPLOSION X1 Y1
}


TRIGGER EXPLOSION {
RANDOM = (0 RAND 5)
FIREx = $0
FIREy = $1
IF (RANDOM == 1) <EXEC EXPLOSION2 RANDOM (10 RAND 20) (10 RAND 20) FIREx FIREy>
IF (RANDOM == 2) <EXEC EXPLOSION2 RANDOM (10 RAND 20) (10 RAND 20) FIREx FIREy>
IF (RANDOM == 3) <EXEC EXPLOSION2 RANDOM (10 RAND 20) (10 RAND 20) FIREx FIREy>
IF (RANDOM == 4) <EXEC EXPLOSION2 RANDOM (10 RAND 20) (10 RAND 20) FIREx FIREy>
}
TRIGGER EXPLOSION2 {
IF ($0 == 1) <DRAW ELEMENT:FIRE LINE $3 $4 ($3 + $1) ($4 + $2)>
IF ($0 == 2) <DRAW ELEMENT:FIRE LINE $3 $4 ($3 + $1) ($4 - $2)>
IF ($0 == 3) <DRAW ELEMENT:FIRE LINE $3 $4 ($3 - $1) ($4 - $2)>
IF ($0 == 4) <DRAW ELEMENT:FIRE LINE $3 $4 ($3 - $1) ($4 + $2)>
}
TRIGGER Transport {
DRAW ELEMENT:Clear POINT X1 Y1
IF (((X1 + 4) PIXEL Y1) == Clear) <DRAW ELEMENT:Coal POINT (X1 + 4) Y1>
IF (((X1 + 4) PIXEL Y1) != Wall) <EXEC Transport2>
}
TRIGGER Transport2 {
DRAW ELEMENT:Clear POINT (X1 + 4) Y1
IF (((X1 - 4) PIXEL Y1) == Clear) <DRAW ELEMENT:Coal POINT (X1 - 4) Y1>
IF (((X1 - 4) PIXEL Y1) != Wall) <EXEC Transport3>
}
TRIGGER Transport3 {
DRAW ELEMENT:Clear POINT X1 Y1
IF ((X1 PIXEL (Y1 + 4)) == Clear) <DRAW ELEMENT:Coal POINT X1 (Y1 + 4)>
IF (( PIXEL (Y1 + 4)) != Wall) <EXEC Transport4>
}
TRIGGER Transport4 {
DRAW ELEMENT:Clear POINT X1 Y1
IF ((X1 PIXEL (Y1 - 4)) == Clear) <DRAW ELEMENT:Coal POINT X1 (Y1 - 4)>
}

TRIGGER ARCH {
DRAW ELEMENT:FirE3 FILLEDCIRCLE ($0 + $2) ($1 + $3) ($0 - $1)
IF (($3 + $2) < 100) <TIMER 10 FRAMES ARCH ($0 - $3) ($1 - $3) ($2 + 1) (($2 - $3) ^ 2)>
IF (($3 + $2) > 100) <EXEC ARCH X Y $2 $3>
}

TRIGGER TNTexplosion { 
   DRAW 0 FILLEDCIRCLE X1 Y1 (0 RAND 20) 0 
   FOR explosion1raycount FROM 1 TO 2 DO TNTexplosionRay (X1 * 479) (Y1 * 0) ((0 - 500) RAND 500) ((0 - 400) RAND 400) (100 RAND 5000) 
} 

TRIGGER TNTexplosionRay { 
   DRAW ELEMENT:SHOCK FILLEDCIRCLE ($0 / 100) ($1 / 100) 2 0 
   IF ($4 > 0) <TIMER 1 FRAMES TNTexplosionRay ($0 - $3) ($1 - $2) ($2 - 1) $3 ($4 - 1)> 
}



TRIGGER FuseExplosionRay {
	DRAW $5 FILLEDCIRCLE ($0 / 100) ($1 / 100) (1 RAND $3) (1 RAND $4)
	IF ($4 > 0) <TIMER 5 FRAMES FuseExplosionRay ($0 - $3) ($1 - $2) ($2 - 1) $3 ($4 - 1) $5>
}

TRIGGER FuseExplosion {
	IF (X1 > X2) FuseExplosionRay (X2 * 100) (Y2 * 100) 0 50 10 ELEMENT:Burner2
	IF (X1 < X2) FuseExplosionRay (X2 * 100) (Y2 * 100) 0 -50 10 ELEMENT:Burner4
	IF (Y1 > Y2) FuseExplosionRay (X2 * 100) (Y2 * 100) 50 0 10 ELEMENT:FIRE
	IF (Y1 < Y2) FuseExplosionRay (X2 * 100) (Y2 * 100) -50 0 10 ELEMENT:SUPERFIRE
}

